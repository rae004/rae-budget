# Database Configuration
POSTGRES_USER=rae_budget
POSTGRES_PASSWORD=changeme
POSTGRES_DB=rae_budget
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=1
